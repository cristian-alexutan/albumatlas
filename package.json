{
  "name": "albumatlas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:full": "concurrently --names \"next,api\" --prefix-colors \"cyan,yellow\" \"node scripts/dev.js\" \"npm --prefix server run dev\"",
    "dev:local": "set NEXT_PUBLIC_API_URL=http://localhost:4000&& next dev --hostname 0.0.0.0",
    "dev:phone": "set \"ALBUMATLAS_LAN_IP=192.168.9.91\"&& node scripts/dev.js",
    "dev:next": "next dev",
    "dev:api": "npm --prefix server run dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "3.2.4",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^24.1.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "3.2.4"
  }
}
