# Copy this file to .env and fill in your values.

# PostgreSQL connection string.
# Without this variable the server falls back to in-memory storage.
DATABASE_URL=postgresql://albumatlas:albumatlas123@localhost:5432/albumatlas

# Server port (default: 4000)
PORT=4000

# Allowed CORS origins (comma-separated).
CORS_ORIGIN=http://localhost:3000

# Gmail SMTP – used to send email verification codes.
# Generate an App Password at: https://myaccount.google.com/apppasswords
# If these are unset the code is printed to the server console instead.
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optional: override the TOTP secrets used for dev seed users (admin / user).
# Leave blank to use the built-in defaults.
# SEED_ADMIN_TOTP=JBSWY3DPEHPK3PXP
# SEED_USER_TOTP=NBSWY3DPEHPK3PXP
